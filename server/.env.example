# App
APP_NAME=企业级RAG智能助手
APP_VERSION=0.1.0
APP_ENV=dev
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5175","http://127.0.0.1:5175"]
DEFAULT_STAGE=M1
PRODUCTION_LIKE_ENVS=["staging","prod","production"]

# Database
DATABASE_URL=sqlite:///./storage/enterprise_rag.db
DATABASE_SCHEMA_STRATEGY=auto
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Auth
AUTH_ENABLED=true
AUTH_SECRET_KEY=change-this-in-production
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Workflow
WORKFLOW_CHECKPOINTER_BACKEND=auto
WORKFLOW_CHECKPOINTER_POSTGRES_URL=postgresql://rag:rag@localhost:5432/enterprise_rag

# Vector store
QDRANT_USE_LOCAL=true
QDRANT_URL=http://localhost:6333
QDRANT_PATH=./storage/qdrant
QDRANT_COLLECTION_NAME=document_chunks

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_ALLOWED_MODELS=["BAAI/bge-large-zh-v1.5"]
OPENAI_EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
OPENAI_EMBEDDING_DIMENSIONS=1024
OPENAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_API_KEY_ENV_VAR=SILICONFLOW_API_KEY
OPENAI_EMBEDDING_REQUEST_TIMEOUT_SECONDS=30
OPENAI_EMBEDDING_SSL_VERIFY=true

# LLM
LLM_PROVIDER=openai
LLM_ALLOWED_MODELS=["gpt-4o-mini","gpt-4o","gpt-4.1"]
OPENAI_LLM_MODEL_NAME=gpt-4o-mini
OPENAI_LLM_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_API_KEY=
OPENAI_LLM_API_KEY_ENV_VAR=
OPENAI_LLM_REQUEST_TIMEOUT_SECONDS=60
EVALUATION_LLM_REQUEST_TIMEOUT_SECONDS=180
OPENAI_LLM_SSL_VERIFY=true
OPENAI_LLM_TEMPERATURE=0.2
OPENAI_LLM_MAX_CONTEXT_CITATIONS=6
LLM_PRICING_JSON=

# Chat / retrieval
CHAT_MEMORY_MESSAGE_WINDOW=6
MAX_CHAT_SELECTED_KB_COUNT=3
RETRIEVAL_PER_KB_TOP_K=4
RETRIEVAL_OVERFETCH_FACTOR=3
RETRIEVAL_DENSE_WEIGHT=0.65
RETRIEVAL_LEXICAL_WEIGHT=0.35

# Langfuse Cloud observability / evaluation POC
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# 留空时：dev 默认 1.0，staging/prod 默认 0.2；显式填写则以填写值为准
LANGFUSE_SAMPLE_RATE=
LANGFUSE_CAPTURE_INPUT_OUTPUT=false
LANGFUSE_CITATION_CONTENT_LIMIT=240
LANGFUSE_PROMPT_MANAGEMENT_ENABLED=false
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=60

# Jobs / storage
SYSTEM_JOB_BATCH_RETRY_LIMIT=20
STORAGE_ROOT=./storage

# Local secrets
SILICONFLOW_API_KEY=
